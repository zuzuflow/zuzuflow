# =============================================================================
# ZuzuFlow — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values before running the platform.

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://workflow:workflow_secret@localhost:5432/workflow_db"

# -----------------------------------------------------------------------------
# Temporal
# -----------------------------------------------------------------------------
TEMPORAL_ADDRESS="localhost:7233"
TEMPORAL_NAMESPACE="default"
TEMPORAL_TASK_QUEUE="workflow-interpreter"
# Optional mTLS certs (leave empty for local dev)
TEMPORAL_TLS_CERT_PATH=""
TEMPORAL_TLS_KEY_PATH=""

# -----------------------------------------------------------------------------
# Backend Server
# -----------------------------------------------------------------------------
PORT=4000
NODE_ENV="development"
# Allowed CORS origins (comma-separated)
CORS_ORIGINS="http://localhost:3000,http://localhost:4000"
# Secret used to sign webhook inbound tokens
WEBHOOK_SECRET="replace_me_with_a_random_32char_secret"

# -----------------------------------------------------------------------------
# Email (SMTP — used by sendEmailActivity when provider=smtp)
# -----------------------------------------------------------------------------
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="you@example.com"
SMTP_PASS="your_smtp_password"
SMTP_FROM="\"ZuzuFlow\" <no-reply@zuzuflow.com>"

# -----------------------------------------------------------------------------
# SendGrid (used by sendEmailActivity when provider=sendgrid)
# -----------------------------------------------------------------------------
SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxxxxxxx"

# -----------------------------------------------------------------------------
# Redis (optional — for future queue/cache use)
# -----------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL="info"

# -----------------------------------------------------------------------------
# MFA (Multi-Factor Authentication)
# -----------------------------------------------------------------------------
# 64-char hex string (32 bytes) — used to AES-256-CBC encrypt TOTP secrets at rest
# Generate a new one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MFA_ENCRYPTION_KEY="67228660edb24227e21e9adb82e248e26fae87b182cbc376a5bf11d8b8f4e00e"
MFA_ISSUER="ZuzuFlow"
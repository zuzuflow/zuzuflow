{
  "name": "@zuzuflow/nodejs-sdk",
  "version": "0.1.0",
  "description": "Node.js SDK for the ZuzuFlow API — workflows, executions, tags, folders, and live trigger streaming",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zuzuflow/zuzuflow.git",
    "directory": "sdk/nodejs-sdk"
  },
  "homepage": "https://github.com/zuzuflow/zuzuflow/tree/main/sdk/nodejs-sdk#readme",
  "keywords": [
    "zuzuflow",
    "workflow",
    "automation",
    "sdk",
    "api-client"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.14",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}

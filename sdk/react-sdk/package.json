{
  "name": "@zuzuflow/react-sdk",
  "version": "0.1.0",
  "description": "Embeddable React UI components for ZuzuFlow — workflow editor, runtime app shell, and API provider",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zuzuflow/zuzuflow.git",
    "directory": "sdk/react-sdk"
  },
  "homepage": "https://github.com/zuzuflow/zuzuflow/tree/main/sdk/react-sdk#readme",
  "keywords": [
    "zuzuflow",
    "workflow",
    "automation",
    "react",
    "editor",
    "ui"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "react": "^18",
    "react-dom": "^18"
  },
  "dependencies": {
    "@xyflow/react": "^12.3.0",
    "@monaco-editor/react": "^4.6.0",
    "clsx": "^2.1.1",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.378.0",
    "react-router-dom": "^7.14.0",
    "tailwind-merge": "^2.3.0",
    "uuid": "^9.0.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vite-plugin-dts": "^3.9.1"
  }
}

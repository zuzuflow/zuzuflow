# =============================================================================
# ZuzuFlow — production self-host environment template
#
# For single-node self-hosting with docker-compose.prod.yml.
# (For running the stack from source for local development, use .env.example.)
#
# Quick setup:
#   cp .env.production.example .env
#   # fill in the REQUIRED values below (or just run ./install.sh)
#   docker compose -f docker-compose.prod.yml up -d
#
# One-liner to generate every secret at once (paste into .env):
#   cat <<EOF
#   JWT_SECRET=$(openssl rand -hex 32)
#   API_TOKEN=$(openssl rand -hex 32)
#   ENCRYPTION_KEY=$(openssl rand -hex 32)
#   MFA_ENCRYPTION_KEY=$(openssl rand -hex 32)
#   WEBHOOK_SECRET=$(openssl rand -hex 32)
#   POSTGRES_PASSWORD=$(openssl rand -hex 16)
#   INITIAL_ADMIN_PASSWORD=$(openssl rand -hex 12)
#   EOF
# =============================================================================

# ── Image source ────────────────────────────────────────────────────────────
# GHCR namespace (lowercase). Images pulled from:
#   ghcr.io/${ZUZUFLOW_ORG}/workflow-{backend,frontend,workers}
ZUZUFLOW_ORG=zuzuflow
# Pin to a release (e.g. v1.2.3) or stay on latest
ZUZUFLOW_VERSION=latest

# ── Public URL ──────────────────────────────────────────────────────────────
# The URL your reverse proxy serves ZuzuFlow on. Used in outgoing email links +
# CORS. Examples: https://flows.example.com  —or—  http://localhost:3000
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ── Host ports ──────────────────────────────────────────────────────────────
# Frontend binds to 0.0.0.0 (reach it from outside). Backend + Temporal UI
# bind to 127.0.0.1 only — put them behind your reverse proxy.
FRONTEND_PORT=3000
BACKEND_PORT=3001
TEMPORAL_UI_PORT=8080

# ── Postgres (embedded by default) ──────────────────────────────────────────
POSTGRES_USER=zuzuflow
POSTGRES_DB=zuzuflow
# REQUIRED — generate: openssl rand -hex 16
POSTGRES_PASSWORD=

# Using a managed Postgres instead? Set DATABASE_URL and run with:
#   docker compose -f docker-compose.prod.yml --profile external-deps up -d
# DATABASE_URL=postgresql://user:pass@managed-host:5432/zuzuflow

# ── Temporal (embedded by default) ──────────────────────────────────────────
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=workflow-interpreter

# ── REQUIRED secrets. Generate each with `openssl rand -hex 32`. ────────────
# JWT signing key for /api/auth/login tokens.
JWT_SECRET=
# Master machine-to-machine API token.
API_TOKEN=
# AES-256-GCM key for encrypting settings (git PAT, SMTP pass, etc.).
ENCRYPTION_KEY=
# AES-256-GCM key for encrypting MFA TOTP secrets. EXACTLY 64 hex chars.
# ⚠ Never rotate — rotating invalidates every enrolled user's TOTP.
MFA_ENCRYPTION_KEY=
# HMAC secret for inbound webhooks (min 16 chars).
WEBHOOK_SECRET=

# ── MFA ─────────────────────────────────────────────────────────────────────
MFA_ISSUER=ZuzuFlow

# ── Initial superadmin (seeded only on first boot if users table is empty) ──
INITIAL_ADMIN_USERNAME=admin
# REQUIRED — change immediately after first login. Generate: openssl rand -hex 12
INITIAL_ADMIN_PASSWORD=

# ── Signup ──────────────────────────────────────────────────────────────────
# false = only the seeded admin + their invitees can log in.
SIGNUP_ENABLED=true

# ── Email (optional) ────────────────────────────────────────────────────────
# Required for MFA email OTP and org invite emails. Leave blank to log to
# console (safe only for testing).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@zuzuflow.example.com

# ── Logging ─────────────────────────────────────────────────────────────────
# error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info

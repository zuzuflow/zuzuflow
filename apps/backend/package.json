{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec 'ts-node --transpile-only src/index.ts'",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prisma:generate": "prisma generate --schema=src/db/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=src/db/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=src/db/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.13.0",
    "@temporalio/client": "^1.10.3",
    "@workflow/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^6.9.13",
    "otplib": "^13.4.0",
    "qrcode": "^1.5.4",
    "simple-git": "^3.35.2",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "ws": "^8.17.0",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.12.12",
    "@types/nodemailer": "^6.4.14",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "nodemon": "^3.1.0",
    "prisma": "^5.13.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
